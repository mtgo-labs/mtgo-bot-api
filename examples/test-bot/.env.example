# Copy to .env and fill in. .env is gitignored — never commit real tokens.
# Bun auto-loads .env on run.

# Required: bot token from @BotFather.
TOKEN=123456789:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Optional: Bot API server root. Defaults to the local mtgo-bot-api server.
# Set to https://api.telegram.org to compare against the official server.
API_ROOT=http://localhost:8081
